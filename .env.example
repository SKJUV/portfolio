# ============================================
# Variables d'environnement — Portfolio CMS Template
# Copier ce fichier en .env.local et remplir les valeurs
# ============================================

# --- Admin Dashboard ---
# Mot de passe pour accéder au dashboard admin
ADMIN_PASSWORD=your_admin_password
# Clé secrète pour signer les tokens HMAC (générer avec: openssl rand -hex 32)
ADMIN_SECRET=your_hmac_secret_key

# --- Supabase (requis pour la production / Vercel) ---
# URL du projet Supabase (Supabase > Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Clé service_role (Supabase > Settings > API > service_role key)
# ⚠️ NE PAS exposer côté client — utilisée uniquement côté serveur
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Google Gemini AI (optionnel — active le chatbot intelligent) ---
# Clé API Google AI Studio : https://aistudio.google.com/apikey
# Sans cette clé, le chatbot utilisera des réponses pré-programmées
GEMINI_API_KEY=AIzaSy...

# --- Vercel Analytics (automatique si déployé sur Vercel) ---
# Pas de configuration requise — activé par défaut
